#!/bin/sh
set -e

MAVEN_VERSION="3.9.6"
DIST_DIR="$HOME/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MAVEN_HOME="${DIST_DIR}/apache-maven-${MAVEN_VERSION}"
MVN_CMD="${MAVEN_HOME}/bin/mvn"

if [ ! -f "$MVN_CMD" ]; then
    echo "Apache Maven ${MAVEN_VERSION} not found. Downloading..."
    mkdir -p "$DIST_DIR"
    DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/apache-maven-${MAVEN_VERSION}-bin.zip"
    ZIP_FILE="${DIST_DIR}/maven.zip"
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "$DOWNLOAD_URL" -o "$ZIP_FILE"
    elif command -v wget > /dev/null 2>&1; then
        wget -q "$DOWNLOAD_URL" -O "$ZIP_FILE"
    else
        echo "Error: curl or wget is required to download Maven." >&2
        exit 1
    fi
    unzip -q "$ZIP_FILE" -d "$DIST_DIR"
    rm "$ZIP_FILE"
    echo "Maven downloaded successfully."
fi

exec "$MVN_CMD" "$@"
